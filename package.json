{
  "name": "joojoo-messenger",
  "private": true,
  "packageManager": "bun",
  "scripts": {
    "check": "biome check .",
    "format": "biome check --write .",
    "build:web": "bun --filter @joojoo-messenger/web build",
    "build:api": "bun --filter @joojoo-messenger/api build"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.3"
  }
}
